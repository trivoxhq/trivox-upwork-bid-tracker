# Copy to `.env.local` for Next.js. Prisma CLI does NOT load `.env.local` by default —
# use the npm scripts (`npm run db:push`, `npm run db:deploy`, …) which load `.env.local` via dotenv-cli.

# MySQL (Prisma)
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/upwork_bid_tracker"

# JWT — long random string (≥16 chars; 32+ recommended)
JWT_SECRET="replace-with-a-long-random-secret"

# Optional: comma-separated office public IPs. When non-empty, only these IPs may
# call /api/* or open /dashboard; /login stays available to show an error banner.
# Leave empty during local development. Example:
# ALLOWED_OFFICE_IPS="203.0.113.45,198.51.100.10"
ALLOWED_OFFICE_IPS=

# Optional: override default passwords used by prisma/seed.ts
# SEED_ADMIN_PASSWORD=""
# SEED_MEMBER_PASSWORD=""

# Optional: duplicate DATABASE_URL into a root `.env` file if you prefer running
# `npx prisma migrate deploy` directly without dotenv-cli.

# --- Admin destructive actions ---
# When set, "Reset all bid data" (DELETE /api/bids) requires this exact PIN in the JSON body.
# Leave unset for local dev if you want one-click reset without a PIN.
# ADMIN_DESTRUCTIVE_PIN="your-pin"

# --- Cron + daily email summary (POST /api/cron/daily-summary) ---
# CRON_SECRET="long-random-string"
# RESEND_API_KEY="re_..."
# DAILY_SUMMARY_TO="you@example.com"
# Optional sender (must be a verified domain in Resend)
# DAILY_SUMMARY_FROM="Upwork Bid Tracker <onboarding@resend.dev>"

# --- Dashboard client polling (seconds, 5–120; 0 or unset = off) ---
# NEXT_PUBLIC_DASH_POLL_SEC=30
