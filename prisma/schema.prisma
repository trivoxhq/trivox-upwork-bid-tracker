generator client {
  provider = "prisma-client-js"
  // Avoid Windows EPERM when replacing query_engine under node_modules/.prisma (OneDrive / locked dev).
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  manager
  sales_member
  viewer
  member
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  role           Role
  password       String
  dailyTarget    Int      @default(0)
  monthlyTarget  Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  bids           Bid[]
  leadsCreated   Lead[]   @relation("LeadCreatedBy")
  leadsAssigned  Lead[]   @relation("LeadAssignedTo")
  clientsCreated Client[] @relation("ClientCreatedBy")
  clientHistoryCreated ClientHistory[] @relation("ClientHistoryCreatedBy")
  tasksCreated   CrmTask[] @relation("TaskCreatedBy")
  tasksAssigned  CrmTask[] @relation("TaskAssignedTo")
  calendarEventsCreated CalendarEvent[] @relation("CalendarEventCreatedBy")
  calendarEventsOwned   CalendarEvent[] @relation("CalendarEventOwner")
  dealsCreated          Deal[]          @relation("DealCreatedBy")
  dealsOwned            Deal[]          @relation("DealOwner")
  crmNotesCreated       CrmNote[]       @relation("CrmNoteCreatedBy")
  crmAttachmentsCreated CrmAttachment[] @relation("CrmAttachmentCreatedBy")

  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  bids      Bid[]

  @@index([isActive])
  @@map("profiles")
}

model Niche {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  bids      Bid[]

  @@index([isActive])
  @@map("niches")
}

model Bid {
  id        String   @id @default(uuid())
  date      DateTime
  profileId String
  nicheId   String
  client    String
  bidLink   String?
  status    String   @default("New")
  value     Int      @default(0)
  notes     String?
  addedById String
  addedBy   User     @relation(fields: [addedById], references: [id])
  profile   Profile  @relation(fields: [profileId], references: [id])
  niche     Niche    @relation(fields: [nicheId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([addedById])
  @@index([date])
  @@index([status])
  @@index([profileId])
  @@index([nicheId])
  @@map("bids")
}

model Lead {
  id           String   @id @default(uuid())
  title        String
  clientName   String
  email        String?
  phone        String?
  company      String?
  country      String?
  source       String?
  status       String   @default("New")
  notes        String?  @db.Text
  assignedToId String?
  assignedTo   User?    @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User     @relation("LeadCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

model Client {
  id          String          @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  country     String?
  source      String?
  notes       String?         @db.Text
  createdById String
  createdBy   User            @relation("ClientCreatedBy", fields: [createdById], references: [id])
  history     ClientHistory[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([createdById])
  @@index([name])
  @@index([company])
  @@index([source])
  @@index([createdAt])
  @@map("clients")
}

model ClientHistory {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String   @default("Note")
  title       String
  description String?  @db.Text
  occurredAt  DateTime @default(now())
  createdById String
  createdBy   User     @relation("ClientHistoryCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([createdById])
  @@index([type])
  @@index([occurredAt])
  @@map("client_history")
}

model CrmTask {
  id           String    @id @default(uuid())
  title        String
  description  String?   @db.Text
  status       String    @default("Open")
  priority     String    @default("Medium")
  dueAt        DateTime?
  assignedToId String?
  assignedTo   User?     @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@map("crm_tasks")
}

model CalendarEvent {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  type        String    @default("Meeting")
  startsAt    DateTime
  endsAt      DateTime?
  ownerId     String?
  owner       User?     @relation("CalendarEventOwner", fields: [ownerId], references: [id])
  createdById String
  createdBy   User      @relation("CalendarEventCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId])
  @@index([createdById])
  @@index([type])
  @@index([startsAt])
  @@map("calendar_events")
}

model Deal {
  id              String    @id @default(uuid())
  title           String
  clientName      String
  value           Int       @default(0)
  stage           String    @default("Qualification")
  probability     Int       @default(0)
  expectedCloseAt DateTime?
  notes           String?   @db.Text
  ownerId         String?
  owner           User?     @relation("DealOwner", fields: [ownerId], references: [id])
  createdById     String
  createdBy       User      @relation("DealCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([ownerId])
  @@index([createdById])
  @@index([stage])
  @@index([expectedCloseAt])
  @@index([createdAt])
  @@map("deals")
}

model CrmNote {
  id          String          @id @default(uuid())
  entityType  String
  entityId    String
  body        String          @db.Text
  createdById String
  createdBy   User            @relation("CrmNoteCreatedBy", fields: [createdById], references: [id])
  attachments CrmAttachment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([entityType, entityId])
  @@index([createdById])
  @@index([createdAt])
  @@map("crm_notes")
}

model CrmAttachment {
  id           String   @id @default(uuid())
  noteId       String
  note         CrmNote  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  storedName   String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdById  String
  createdBy    User     @relation("CrmAttachmentCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@index([noteId])
  @@index([createdById])
  @@map("crm_attachments")
}
